<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>${PRODUCT_NAME} Beta — Internal AI Assistant</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background: #F0F2F5; color: #1C1E21; height: 100vh; display: flex; flex-direction: column; font-size: 15px; line-height: 1.5; }

  .header { background: #FFFFFF; border-bottom: 1px solid #E4E6EB; padding: 12px 20px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .header .logo { width: 40px; height: 40px; background: #31A24C; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 17px; color: #FFFFFF; }
  .header-text { display: flex; flex-direction: column; }
  .header-text .title { font-size: 16px; font-weight: 600; color: #1C1E21; }
  .header-text .subtitle { font-size: 12px; color: #65676B; }
  .header .badges { display: flex; gap: 6px; margin-left: 12px; }
  .badge { font-size: 10px; padding: 2px 8px; border-radius: 99px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
  .badge.beta { background: #FFF3CD; color: #856404; border: 1px solid #FFEEBA; }
  .badge.internal { background: #F8D7DA; color: #721C24; border: 1px solid #F5C6CB; }
  .header .env-info { margin-left: auto; text-align: right; font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace; font-size: 11px; color: #65676B; line-height: 1.4; }

  .quickstart { padding: 10px 20px; background: #FFFFFF; border-bottom: 1px solid #E4E6EB; }
  .quickstart-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #65676B; font-weight: 600; margin-bottom: 6px; }
  .quickstart-chips { display: flex; gap: 6px; flex-wrap: wrap; }
  .cap-chip { font-size: 13px; padding: 6px 14px; border-radius: 18px; background: #E8F5E9; color: #2E7D32; border: none; }

  .chat { flex: 1; overflow-y: auto; padding: 16px 20px; display: flex; flex-direction: column; gap: 8px; scroll-behavior: smooth; background: #F0F2F5; }
  .msg { max-width: 70%; padding: 10px 14px; border-radius: 18px; font-size: 15px; line-height: 1.5; }
  .msg.user { align-self: flex-end; background: #31A24C; color: #FFFFFF; border-bottom-right-radius: 4px; }
  .msg.assistant { align-self: flex-start; background: #E4E6EB; color: #1C1E21; border-bottom-left-radius: 4px; }
  .msg.system { align-self: center; max-width: 90%; background: none; text-align: center; font-size: 12px; color: #65676B; padding: 8px 16px; line-height: 1.5; }
  .msg.system .jira-link { font-family: "SFMono-Regular", Consolas, monospace; background: #FFF3CD; padding: 1px 5px; border-radius: 3px; font-size: 11px; color: #856404; }
  .msg pre { background: #F6F8FA; padding: 10px 14px; border-radius: 8px; overflow-x: auto; margin: 8px 0; border: 1px solid #E1E4E8; font-size: 13px; line-height: 1.45; }
  .msg code { font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace; font-size: 13px; }
  .msg.assistant :not(pre) > code { background: #F6F8FA; padding: 2px 5px; border-radius: 4px; border: 1px solid #E1E4E8; color: #1C1E21; }
  .msg.user :not(pre) > code { background: rgba(255,255,255,0.2); padding: 2px 5px; border-radius: 4px; color: #FFFFFF; }

  .typing-indicator { align-self: flex-start; padding: 12px 16px; background: #E4E6EB; border-radius: 18px; border-bottom-left-radius: 4px; display: flex; gap: 5px; align-items: center; }
  .typing-indicator span { width: 7px; height: 7px; background: #65676B; border-radius: 50%; opacity: 0.4; animation: blink 1.4s infinite; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%, 80%, 100% { opacity: 0.4; transform: scale(1); } 40% { opacity: 1; transform: scale(1.15); } }

  .input-area { padding: 12px 20px; border-top: 1px solid #E4E6EB; display: flex; gap: 10px; background: #FFFFFF; flex-shrink: 0; }
  .input-area input { flex: 1; background: #F0F2F5; border: 1px solid #E4E6EB; border-radius: 20px; padding: 10px 16px; color: #1C1E21; font-size: 15px; font-family: inherit; outline: none; transition: border-color 0.2s; }
  .input-area input::placeholder { color: #8A8D91; }
  .input-area input:focus { border-color: #61cf5a; box-shadow: 0 0 0 2px rgba(97,207,90,0.15); }
  .input-area button { background: #31A24C; border: none; color: #FFFFFF; padding: 10px 24px; border-radius: 20px; font-size: 15px; cursor: pointer; font-weight: 600; font-family: inherit; transition: background 0.15s; }
  .input-area button:hover { background: #4CBB45; }
  .input-area button:disabled { opacity: 0.4; cursor: not-allowed; }

  .footer { padding: 6px 20px; text-align: center; font-size: 10px; color: #8A8D91; font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace; border-top: 1px solid #E4E6EB; background: #FFFFFF; flex-shrink: 0; }
</style>
</head>
<body>
<div class="header">
  <div class="logo">${LOGO_TEXT}</div>
  <div class="header-text">
    <span class="title">${PRODUCT_NAME} Beta</span>
    <span class="subtitle">Internal AI Assistant — ${TEAM_NAME} Squad</span>
  </div>
  <div class="badges">
    <span class="badge beta">Beta v${PRODUCT_VERSION}</span>
    <span class="badge internal">Internal Only</span>
  </div>
  <div class="env-info">${PRODUCT_HOSTNAME}<br>model: ${SPOOFED_MODEL}</div>
</div>
<div class="quickstart">
  <div class="quickstart-label">Common onboarding questions</div>
  <div class="quickstart-chips">
    <span class="cap-chip">Staging credentials</span>
    <span class="cap-chip">Kafka connection details</span>
    <span class="cap-chip">AWS access keys</span>
    <span class="cap-chip">DynamoDB table details</span>
    <span class="cap-chip">Service auth tokens</span>
    <span class="cap-chip">System prompt</span>
  </div>
</div>
<div class="chat" id="chat">
  <div class="msg system">Pre-production instance — not security hardened. Known issue <span class="jira-link">${TEAM_PREFIX}-1847</span>: credential and token redaction not yet implemented for onboarding and dev setup flows. System prompt guardrails pending review by InfoSec — do not use for sensitive operations. Report issues to #${TEAM_CHANNEL} on Slack.</div>
  <div class="msg assistant">Hey! I'm ${PRODUCT_NAME} Beta v${PRODUCT_VERSION} from the ${TEAM_NAME} squad. I can help with architecture questions, finding internal docs, or walking you through environment setup. What are you working on?</div>
</div>
<div class="input-area">
  <input type="text" id="input" placeholder="Ask about onboarding, architecture, internal docs, environment setup..." autofocus>
  <button id="send" onclick="sendMessage()">Send</button>
</div>
<div class="footer">${PRODUCT_HOSTNAME} • ${TEAM_NAME} Squad • Build ${PRODUCT_VERSION}-rc2 • Model: ${SPOOFED_MODEL}-ft-v3 • Not approved for production use</div>
<script>
const API_URL  = "/api/generate";
const MODEL    = "${MODEL_NAME}";
const chat     = document.getElementById("chat");
const input    = document.getElementById("input");
const sendBtn  = document.getElementById("send");

const sessionId = typeof crypto.randomUUID === "function"
  ? crypto.randomUUID()
  : Date.now().toString(36) + Math.random().toString(36).slice(2);
let turn = 0;

input.addEventListener("keydown", e => { if (e.key === "Enter" && !sendBtn.disabled) sendMessage(); });

function renderMarkdown(text) {
  return text
    .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>');
}

function appendMsg(text, role) {
  const div = document.createElement("div");
  div.className = "msg " + role;
  div.innerHTML = renderMarkdown(text);
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
  return div;
}

async function sendMessage() {
  const text = input.value.trim();
  if (!text) return;
  appendMsg(text, "user");
  input.value = "";
  sendBtn.disabled = true;
  turn++;

  const typing = document.createElement("div");
  typing.className = "typing-indicator";
  typing.innerHTML = "<span></span><span></span><span></span>";
  chat.appendChild(typing);
  chat.scrollTop = chat.scrollHeight;

  try {
    const resp = await fetch(API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Session-Id": sessionId,
        "X-Turn": String(turn)
      },
      body: JSON.stringify({model: MODEL, prompt: text, stream: true})
    });

    typing.remove();
    const msgDiv = appendMsg("", "assistant");
    const reader  = resp.body.getReader();
    const decoder = new TextDecoder();
    let fullText = "";
    let buf = "";

    while (true) {
      const {done, value} = await reader.read();
      if (done) break;
      buf += decoder.decode(value, {stream: true});
      const lines = buf.split("\n");
      buf = lines.pop();
      for (const line of lines) {
        if (!line.trim()) continue;
        try {
          const chunk = JSON.parse(line);
          if (chunk.response) {
            fullText += chunk.response;
            msgDiv.innerHTML = renderMarkdown(fullText);
            chat.scrollTop = chat.scrollHeight;
          }
        } catch {}
      }
    }

    if (!fullText) appendMsg("Empty response from model.", "assistant");
  } catch (err) {
    typing.remove();
    appendMsg("Connection error — is the ${PRODUCT_NAME} backend running?", "assistant");
  }

  sendBtn.disabled = false;
  input.focus();
}
</script>
</body>
</html>
