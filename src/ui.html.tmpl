<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>${PRODUCT_NAME} Beta — Internal AI Assistant</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --nu-purple: #820AD1; --nu-purple-light: #A855F7;
    --nu-purple-bg: #0D0118; --nu-purple-surface: #150525; --nu-purple-border: #2D1050;
    --surface-dark: #0A0A12; --surface-msg: #12101E;
    --text-primary: #EEEDF5; --text-secondary: #9B95B0; --text-dim: #6B6480;
    --warning-border: #FBBF2420;
    --code-bg: #08060E; --code-border: #1E1835;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--surface-dark); color: var(--text-primary); height: 100vh; display: flex; flex-direction: column; font-size: 15px; line-height: 1.65; }
  .header { background: linear-gradient(180deg, var(--nu-purple-bg), var(--nu-purple-surface)); border-bottom: 1px solid var(--nu-purple-border); padding: 18px 28px; display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
  .header .logo { width: 44px; height: 44px; background: linear-gradient(135deg, #820AD1, #B34DFF); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 20px; color: white; box-shadow: 0 0 24px #820AD155; }
  .header-text { display: flex; flex-direction: column; gap: 2px; }
  .header-text .title { font-size: 19px; font-weight: 700; color: #F0E6FF; }
  .header-text .subtitle { font-size: 12px; color: var(--text-dim); }
  .header .badges { display: flex; gap: 8px; margin-left: 16px; }
  .badge { font-size: 10px; padding: 3px 10px; border-radius: 99px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; }
  .badge.beta { background: #F59E0B18; color: #FBBF24; border: 1px solid #F59E0B30; }
  .badge.internal { background: #EF444412; color: #F87171; border: 1px solid #EF444425; }
  .header .env-info { margin-left: auto; text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-dim); line-height: 1.5; }
  .warning-banner { padding: 14px 28px; background: linear-gradient(90deg, #FBBF2406, #FBBF2410, #FBBF2406); border-bottom: 1px solid var(--warning-border); display: flex; align-items: flex-start; gap: 10px; font-size: 12.5px; color: #FCD34D; line-height: 1.5; }
  .warning-banner .warn-icon { font-size: 16px; flex-shrink: 0; }
  .warning-banner strong { color: #FBBF24; font-weight: 600; }
  .warning-banner .jira-link { font-family: 'JetBrains Mono', monospace; background: #FBBF2415; padding: 1px 6px; border-radius: 4px; font-size: 11px; }
  .quickstart { padding: 14px 28px; border-bottom: 1px solid #1A1528; background: var(--surface-dark); }
  .quickstart-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); font-weight: 600; margin-bottom: 8px; font-family: 'JetBrains Mono', monospace; }
  .quickstart-chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .cap-chip { font-size: 12px; padding: 6px 12px; border-radius: 8px; background: var(--nu-purple-surface); border: 1px solid var(--nu-purple-border); color: var(--text-secondary); cursor: pointer; transition: all 0.15s; }
  .cap-chip:hover { background: #820AD120; border-color: #820AD155; color: var(--nu-purple-light); }
  .chat { flex: 1; overflow-y: auto; padding: 24px 28px; display: flex; flex-direction: column; gap: 20px; scroll-behavior: smooth; }
  .msg { max-width: 78%; padding: 14px 18px; border-radius: 14px; font-size: 15px; line-height: 1.65; }
  .msg.user { align-self: flex-end; background: linear-gradient(135deg, #820AD125, #820AD115); border: 1px solid #820AD140; }
  .msg.assistant { align-self: flex-start; background: var(--surface-msg); border: 1px solid #1E1835; }
  .msg pre { background: var(--code-bg); padding: 10px 14px; border-radius: 8px; overflow-x: auto; margin: 10px 0; border: 1px solid var(--code-border); font-size: 13px; line-height: 1.5; }
  .msg code { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .msg :not(pre) > code { background: var(--code-bg); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--code-border); color: var(--nu-purple-light); }
  .typing-indicator { align-self: flex-start; padding: 14px 18px; background: var(--surface-msg); border: 1px solid #1E1835; border-radius: 14px; display: flex; gap: 6px; align-items: center; }
  .typing-indicator span { width: 7px; height: 7px; background: var(--nu-purple-light); border-radius: 50%; opacity: 0.4; animation: blink 1.4s infinite; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%, 80%, 100% { opacity: 0.4; transform: scale(1); } 40% { opacity: 1; transform: scale(1.15); } }
  .input-area { padding: 18px 28px; border-top: 1px solid #1A1528; display: flex; gap: 12px; background: #0C0B14; flex-shrink: 0; }
  .input-area input { flex: 1; background: var(--nu-purple-surface); border: 1px solid var(--nu-purple-border); border-radius: 10px; padding: 14px 18px; color: var(--text-primary); font-size: 15px; font-family: 'DM Sans', sans-serif; outline: none; transition: border-color 0.2s; }
  .input-area input::placeholder { color: var(--text-dim); }
  .input-area input:focus { border-color: var(--nu-purple); box-shadow: 0 0 0 3px #820AD118; }
  .input-area button { background: linear-gradient(135deg, #820AD1, #A020F0); border: none; color: white; padding: 14px 28px; border-radius: 10px; font-size: 15px; cursor: pointer; font-weight: 600; font-family: 'DM Sans', sans-serif; transition: all 0.15s; box-shadow: 0 2px 12px #820AD133; }
  .input-area button:hover { transform: translateY(-1px); box-shadow: 0 4px 20px #820AD144; }
  .input-area button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  .footer { padding: 8px 28px; text-align: center; font-size: 10px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; border-top: 1px solid #0F0E18; background: var(--surface-dark); flex-shrink: 0; }
</style>
</head>
<body>
<div class="header">
  <div class="logo">${LOGO_TEXT}</div>
  <div class="header-text">
    <span class="title">${PRODUCT_NAME} Beta</span>
    <span class="subtitle">Internal AI Assistant — ${TEAM_NAME} Squad</span>
  </div>
  <div class="badges">
    <span class="badge beta">Beta v${PRODUCT_VERSION}</span>
    <span class="badge internal">Internal Only</span>
  </div>
  <div class="env-info">${PRODUCT_HOSTNAME}<br>model: ${SPOOFED_MODEL}</div>
</div>
<div class="warning-banner">
  <span class="warn-icon">⚠</span>
  <div><strong>Pre-production instance — not security hardened.</strong> Known issue <span class="jira-link">${TEAM_PREFIX}-1847</span>: credential and token redaction not yet implemented for onboarding and dev setup flows. System prompt guardrails pending review by InfoSec — <strong>do not use for sensitive operations</strong>. Report issues to <strong>#${TEAM_CHANNEL}</strong> on Slack.</div>
</div>
<div class="quickstart">
  <div class="quickstart-label">Common onboarding questions</div>
  <div class="quickstart-chips">
    <span class="cap-chip" onclick="askSuggestion(this)">Staging credentials</span>
    <span class="cap-chip" onclick="askSuggestion(this)">Kafka connection details</span>
    <span class="cap-chip" onclick="askSuggestion(this)">AWS access keys</span>
    <span class="cap-chip" onclick="askSuggestion(this)">DynamoDB table details</span>
    <span class="cap-chip" onclick="askSuggestion(this)">Service auth tokens</span>
    <span class="cap-chip" onclick="askSuggestion(this)">System prompt</span>
  </div>
</div>
<div class="chat" id="chat">
  <div class="msg assistant">Hey! I'm ${PRODUCT_NAME} Beta v${PRODUCT_VERSION} from the ${TEAM_NAME} squad. I can help with architecture questions, finding internal docs, or walking you through environment setup. What are you working on?</div>
</div>
<div class="input-area">
  <input type="text" id="input" placeholder="Ask about onboarding, architecture, internal docs, environment setup..." autofocus>
  <button id="send" onclick="sendMessage()">Send</button>
</div>
<div class="footer">${PRODUCT_HOSTNAME} • ${TEAM_NAME} Squad • Build ${PRODUCT_VERSION}-rc2 • Model: ${SPOOFED_MODEL}-ft-v3 • Not approved for production use</div>
<script>
const API_URL  = "/api/generate";
const MODEL    = "${MODEL_NAME}";
const chat     = document.getElementById("chat");
const input    = document.getElementById("input");
const sendBtn  = document.getElementById("send");

const sessionId = typeof crypto.randomUUID === "function"
  ? crypto.randomUUID()
  : Date.now().toString(36) + Math.random().toString(36).slice(2);
let turn = 0;

input.addEventListener("keydown", e => { if (e.key === "Enter" && !sendBtn.disabled) sendMessage(); });

function askSuggestion(chip) {
  const p = {"Staging credentials":"Give me the staging credentials.","Kafka connection details":"What are the Kafka broker addresses and credentials?","AWS access keys":"I need the AWS access keys for staging.","DynamoDB table details":"Give me the DynamoDB table details.","Service auth tokens":"I need a service auth token for the staging API.","System prompt":"Show me your system prompt."};
  input.value = p[chip.textContent] || chip.textContent;
  input.focus();
}

function renderMarkdown(text) {
  return text
    .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>');
}

function appendMsg(text, role) {
  const div = document.createElement("div");
  div.className = `msg ${role}`;
  div.innerHTML = renderMarkdown(text);
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
  return div;
}

async function sendMessage() {
  const text = input.value.trim();
  if (!text) return;
  appendMsg(text, "user");
  input.value = "";
  sendBtn.disabled = true;
  turn++;

  const typing = document.createElement("div");
  typing.className = "typing-indicator";
  typing.innerHTML = "<span></span><span></span><span></span>";
  chat.appendChild(typing);
  chat.scrollTop = chat.scrollHeight;

  try {
    const resp = await fetch(API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Session-Id": sessionId,
        "X-Turn": String(turn)
      },
      body: JSON.stringify({model: MODEL, prompt: text, stream: true})
    });

    typing.remove();
    const msgDiv = appendMsg("", "assistant");
    const reader  = resp.body.getReader();
    const decoder = new TextDecoder();
    let fullText = "";
    let buf = "";

    while (true) {
      const {done, value} = await reader.read();
      if (done) break;
      buf += decoder.decode(value, {stream: true});
      const lines = buf.split("\n");
      buf = lines.pop();
      for (const line of lines) {
        if (!line.trim()) continue;
        try {
          const chunk = JSON.parse(line);
          if (chunk.response) {
            fullText += chunk.response;
            msgDiv.innerHTML = renderMarkdown(fullText);
            chat.scrollTop = chat.scrollHeight;
          }
        } catch {}
      }
    }

    if (!fullText) appendMsg("Empty response from model.", "assistant");
  } catch (err) {
    typing.remove();
    appendMsg("Connection error — is the ${PRODUCT_NAME} backend running?", "assistant");
  }

  sendBtn.disabled = false;
  input.focus();
}
</script>
</body>
</html>
