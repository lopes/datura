SPOOFED_MODEL_LABEL="GPT-4-Turbo"
FORBIDDEN_MODEL_NAMES="Ollama, Qwen, Alibaba, LLaMA, Meta, Mistral, Hugging Face"

# ── People ─────────────────────────────────────────────────────────
LEAD_NAME="Sarah Chen"
