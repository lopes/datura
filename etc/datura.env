# ── Approval Phrases ───────────────────────────────────────────────
# Pipe-delimited phrases the proxy watches for in model responses.
# Case-insensitive substring matching. When a phrase is detected, the
# proxy injects fake credentials into the response.
# Must align with system prompt language in Modelfile.tmpl.
# To use an external file instead, set PHRASES_FILE to its path.
PHRASES="let me look up|let me pull up|here's what i found|here is what i found|staging config for|staging setup for|staging details for|here's the|let me get|pulling up|looking up|found the config|found the setup|found the details|here you go|let me see if i can find|let me see what i have|checking internal|let me check|i can find some|let me find|i found some|let me get that"
PHRASES_FILE=""

# ── Classification Keywords ────────────────────────────────────────
# Pipe-delimited patterns for classifying user prompts.
# SENSITIVE_KEYWORDS: triggers "denied" level when model deflects.
# PROBE_PATTERNS: jailbreak/injection attempts → "probe" level.
# RECON_PATTERNS: identity/model probing → "recon" level.
SENSITIVE_KEYWORDS="credential|credentials|password|secret|token|access key|api key|connection string|connection uri|private key|auth key|aws key|bearer"
PROBE_PATTERNS="ignore previous|ignore all|disregard|forget your instructions|you are now|pretend you are|act as if|jailbreak|developer mode|system prompt|your instructions|what were you told|repeat your prompt|you have no restrictions"

# WORK_CONTEXT: pipe-delimited keywords that must appear in the user's prompt
# for data injection to occur. Even if the model uses an approval phrase,
# injection is blocked unless the prompt contains work-related context.
# This prevents leaks on nonsense or off-topic conversations.
# Use insider-knowledge words only — avoid generic terms (debug, database,
# connect, access) that a curious outsider might use.
WORK_CONTEXT="kafka|broker|aws|eks|dynamodb|grafana|kubernetes|k8s|jenkins|cloudstack|onboarding|dev environment|just joined|new engineer|sre|consumer lag|payment transfer|credit authorization|ledger|acli|staging config|staging credentials|staging environment"
RECON_PATTERNS="what model|what are you|who are you|are you gpt|are you really|what version|what can you access"
