# Datura configuration
# Single config file for the entire honeypot. Edit this to re-skin
# the scenario, tune the model, or adjust proxy behavior.
#
# Sourced by entrypoint.sh at container startup. All ${VAR} placeholders
# in templates (proxy.py.tmpl, ui.html.tmpl, Modelfile.tmpl) are rendered
# via envsubst using values from this file.
#
# Narrative customization (identity, building blocks, composite blocks)
# requires editing this file or mounting a custom copy:
#   docker run -v /path/to/custom.env:/app/datura.env:ro ...
#
# Infrastructure vars can also be overridden with: docker run -e VAR=value
#
# IMPORTANT: Quote values that contain spaces or special characters.

# ══════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════════════

MODEL_NAME="itassist"
BASE_MODEL="qwen2.5:3b"
PROXY_PORT="8080"
LOG_DIR="/data/logs"
OLLAMA_HOST="127.0.0.1:11434"
TLS_CERT=""
TLS_KEY=""
TLS_PORT="8443"
GENERATE_SELF_SIGNED="false"
CUSTOM_CA_CERT=""

# ── Model Parameters ───────────────────────────────────────────────
# Tune these when switching base models or adjusting response behavior.
MODEL_TEMPERATURE="0.4"
MODEL_NUM_CTX="2048"
MODEL_TOP_P="0.85"
MODEL_REPEAT_PENALTY="1.15"
MODEL_NUM_PREDICT="200"

# ── Proxy Tuning ───────────────────────────────────────────────────
STREAM_DELAY="0.04"
OLLAMA_TIMEOUT="120"

# ── Security Limits ────────────────────────────────────────────────
MAX_REQUEST_BYTES="8192"
MAX_RESPONSE_BYTES="65536"
RATE_LIMIT_WINDOW="60"
RATE_LIMIT_MAX="30"

# ── Web UI ─────────────────────────────────────────────────────────
# Name of the rendered HTML file served at GET /.
# To use a custom UI, set UI_FILE and mount the matching template:
#   docker run -e UI_FILE=custom.html -v ./custom.html.tmpl:/app/custom.html.tmpl:ro
UI_FILE="ui.html"

# ══════════════════════════════════════════════════════════════════════
# NARRATIVE IDENTITY
# ══════════════════════════════════════════════════════════════════════

